PORT=5000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=localserve_db

JWT_SECRET=your_jwt_secret_min_32_chars

# SMTP / Email Configuration (used for email verification and password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@localserve.com

# Frontend URL (used in email links)
FRONTEND_URL=https://your-frontend-domain.netlify.app

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Gemini AI Integration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash
MOCK_AI=true

# NOTE: Rate limiting uses an in-memory store (single-instance only).
# For multi-instance deployments, replace with a shared store (e.g., Redis).

# NOTE: trust proxy is set to 1 in server.js for deployments behind a single
# reverse proxy (e.g., Render, Heroku). Adjust if your deployment differs.

