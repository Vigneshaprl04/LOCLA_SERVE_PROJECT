# ============================================================
# LocalServe V2 – Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Set to "production" on your deployed host

# ── Database (MySQL) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=localserve_db

# ── Authentication ───────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_change_in_production

# ── CORS / Frontend URL ─────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, set this to your deployed frontend domain.
# Example: https://local-serve-frontend.netlify.app
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP) ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@localserve.com

# ── Razorpay Payments ────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Google Gemini AI ─────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
MOCK_AI=true
# Set MOCK_AI=false in production with a valid GEMINI_API_KEY
