# ============================================================
# LocalServe V2 – Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Vite requires all client-side env vars to be prefixed VITE_
# ============================================================

# ── API Base URL ─────────────────────────────────────────────
# Points to the backend REST API.
# Development:  http://localhost:5000/api
# Production:   https://your-backend-domain.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# ── Socket.IO URL ────────────────────────────────────────────
# Points to the backend Socket.IO server (no /api suffix).
# Development:  http://localhost:5000
# Production:   https://your-backend-domain.onrender.com
VITE_SOCKET_URL=http://localhost:5000
